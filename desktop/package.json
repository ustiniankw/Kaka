{
  "name": "kaka-desktop",
  "version": "1.0.0",
  "description": "Kaka 桌面宠物 — 透明总在最前 Electron 壳",
  "main": "main.js",
  "author": "ustiniankw",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "devDependencies": {
    "electron": "30.5.1",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.ustiniankw.kaka",
    "productName": "Kaka",
    "asar": true,
    "files": ["main.js", "preload.js", "build/**"],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Game"
    },
    "publish": {
      "provider": "github",
      "owner": "ustiniankw",
      "repo": "Kaka"
    }
  }
}
